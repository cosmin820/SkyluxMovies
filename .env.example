# Your full production domain — used for sitemap and canonical URLs
SITE_URL=https://yoursite.onrender.com

# ── Trakt.tv API (strongly recommended — powers trending & genre rows) ──
# 1. Go to https://trakt.tv/oauth/applications
# 2. Click "New Application"
# 3. Name: SkyluxMovies, Redirect URI: urn:ietf:wg:oauth:2.0:oob
# 4. Copy the "Client ID" — paste it here
TRAKT_CLIENT_ID=your_trakt_client_id_here

# ── Optional ──────────────────────────────────────────────────────
# If set, external API requests must include ?key= or x-api-key header
API_KEY=

# Set automatically by Render — do not set manually
# PORT=3000

# ── YTS API URLs ───────────────────────────────────────────────────
# Update these if YTS changes domains
YTS_BASE=https://movies-api.accel.li/api/v2
YTS_FALLBACK=https://yts.bz/api/v2
